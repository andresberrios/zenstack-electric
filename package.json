{
  "name": "zenstack-electric",
  "type": "module",
  "version": "0.0.0",
  "packageManager": "pnpm@10.30.3",
  "description": "Compile ZenStack access policies into Electric SQL shape filters",
  "author": "Andres Berrios",
  "license": "MIT",
  "homepage": "https://github.com/andresberrios/zenstack-electric#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andresberrios/zenstack-electric.git"
  },
  "bugs": "https://github.com/andresberrios/zenstack-electric/issues",
  "keywords": [
    "zenstack",
    "electric",
    "electric-sql",
    "access-control",
    "policy",
    "shape-filter"
  ],
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint",
    "prepublishOnly": "nr build",
    "release": "bumpp",
    "start": "tsx src/index.ts",
    "test": "vitest run",
    "test:unit": "vitest run --exclude test/e2e",
    "test:e2e": "vitest run test/e2e",
    "typecheck": "tsc",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@zenstackhq/schema": "^3.4.4",
    "@zenstackhq/sdk": "^3.4.4"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.6.1",
    "@antfu/ni": "^28.0.0",
    "@antfu/utils": "^9.3.0",
    "@electric-sql/client": "^1.5.11",
    "@types/node": "^25.0.1",
    "@types/pg": "^8.18.0",
    "@zenstackhq/cli": "^3.4.4",
    "@zenstackhq/orm": "^3.4.4",
    "@zenstackhq/plugin-policy": "^3.4.4",
    "bumpp": "^10.3.2",
    "eslint": "^9.39.2",
    "lint-staged": "^16.2.7",
    "pg": "^8.20.0",
    "publint": "^0.3.16",
    "simple-git-hooks": "^2.13.1",
    "tinyexec": "^1.0.2",
    "tsdown": "^0.17.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "vitest": "^4.0.15",
    "vitest-package-exports": "^0.1.1",
    "yaml": "^2.8.2"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm i --frozen-lockfile --ignore-scripts --offline && npx lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
